# PERSEUS run-service · environment template (NO SECRETS HERE)
# Copy to .env (gitignored) and fill in. Never commit real values.

# --- Front end (Vite, build-time; only the anon/public values belong here) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_PADDLE_CLIENT_TOKEN=          # Paddle.js client-side token (public)
VITE_PADDLE_PRICE_ID=             # the subscription price to open at checkout

# --- Supabase Edge Functions (server-side secrets; set via `supabase secrets set`) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # service role — server only, never ship to the browser
PADDLE_WEBHOOK_SECRET=            # Paddle notification signing secret
CARDINAL_DISPATCH_URL=           # URL of the run-service backend that holds the SSH/SLURM creds

# --- Cardinal dispatcher backend (run-service/backend) ---
CARDINAL_HOST=cardinal.osc.edu
CARDINAL_USER=
CARDINAL_SSH_KEY_PATH=            # path to the deploy key on the backend host
CARDINAL_ACCOUNT=PUOM0008        # SLURM account
PERSEUS_RUN_DIR=~/perseus_run    # runner location on Cardinal
